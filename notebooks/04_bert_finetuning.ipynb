        "    COLAB = False\n",
        "    print('Ambiente: Local')\n",
        "\n",
        "import torch\n",
        "GPU = torch.cuda.is_available()\n",
        "print(f'GPU disponível: {GPU}')\n",
        "if GPU:\n",
        "    print(f'  {torch.cuda.get_device_name(0)} — VRAM: {torch.cuda.get_device_properties(0).total_memory / 1e9:.1f} GB')"
